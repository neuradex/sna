{
  "name": "@sna-sdk/react",
  "version": "0.0.0",
  "description": "Skills-Native Application React bindings — hooks, components, and stores",
  "type": "module",
  "files": [
    "dist/"
  ],
  "exports": {
    "./components/sna-provider": {
      "source": "./src/components/sna-provider.tsx",
      "types": "./dist/components/sna-provider.d.ts",
      "default": "./dist/components/sna-provider.js"
    },
    "./components/chat": {
      "source": "./src/components/chat/index.ts",
      "types": "./dist/components/chat/index.d.ts",
      "default": "./dist/components/chat/index.js"
    },
    "./hooks": {
      "source": "./src/hooks/index.ts",
      "types": "./dist/hooks/index.d.ts",
      "default": "./dist/hooks/index.js"
    },
    "./stores/chat-store": {
      "source": "./src/stores/chat-store.ts",
      "types": "./dist/stores/chat-store.d.ts",
      "default": "./dist/stores/chat-store.js"
    },
    "./context": {
      "source": "./src/context.ts",
      "types": "./dist/context.d.ts",
      "default": "./dist/context.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "claude-code",
    "sna",
    "skills-native",
    "react"
  ],
  "dependencies": {
    "@sna-sdk/core": "workspace:*",
    "marked": "^17.0.5"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "zustand": ">=4.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}

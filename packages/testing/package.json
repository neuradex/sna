{
  "name": "@sna-sdk/testing",
  "version": "0.9.9",
  "description": "Testing utilities for SNA — mock Anthropic API, oneshot runner, and sna-test CLI",
  "type": "module",
  "bin": {
    "sna-test": "bin/sna-test.js"
  },
  "files": [
    "bin/",

  "keywords": [
    "sna",
    "skills-native",
    "testing",
    "mock"
  ],
  "dependencies": {
    "chalk": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}

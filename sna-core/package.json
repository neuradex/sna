{
  "name": "sna",
  "version": "0.2.0",
  "description": "Skills-Native Application primitives — runtime, event bus, agent providers, and React hooks",
  "type": "module",
  "bin": {
    "sna": "bin/sna.js"
  },
  "files": [
    "bin/",
    "dist/",
    "skills/",
    "CLAUDE.md.template"
  ],
  "exports": {
    "./server": {
      "source": "./src/server/index.ts",
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./server/routes/events": {
      "source": "./src/server/routes/events.ts",
      "types": "./dist/server/routes/events.d.ts",
      "default": "./dist/server/routes/events.js"
    },
    "./server/routes/emit": {
      "source": "./src/server/routes/emit.ts",
      "types": "./dist/server/routes/emit.d.ts",
      "default": "./dist/server/routes/emit.js"
    },
    "./server/routes/run": {
      "source": "./src/server/routes/run.ts",
      "types": "./dist/server/routes/run.d.ts",
      "default": "./dist/server/routes/run.js"
    },
    "./server/routes/agent": {
      "source": "./src/server/routes/agent.ts",
      "types": "./dist/server/routes/agent.d.ts",
      "default": "./dist/server/routes/agent.js"
    },
    "./db/schema": {
      "source": "./src/db/schema.ts",
      "types": "./dist/db/schema.d.ts",
      "default": "./dist/db/schema.js"
    },
    "./components/sna-provider": {
      "source": "./src/components/sna-provider.tsx",
      "types": "./dist/components/sna-provider.d.ts",
      "default": "./dist/components/sna-provider.js"
    },
    "./components/chat": {
      "source": "./src/components/chat/index.ts",
      "types": "./dist/components/chat/index.d.ts",
      "default": "./dist/components/chat/index.js"
    },
    "./hooks": {
      "source": "./src/hooks/index.ts",
      "types": "./dist/hooks/index.d.ts",
      "default": "./dist/hooks/index.js"
    },
    "./stores/chat-store": {
      "source": "./src/stores/chat-store.ts",
      "types": "./dist/stores/chat-store.d.ts",
      "default": "./dist/stores/chat-store.js"
    },
    "./providers": {
      "source": "./src/core/providers/index.ts",
      "types": "./dist/core/providers/index.d.ts",
      "default": "./dist/core/providers/index.js"
    },
    "./lib/sna-run": {
      "source": "./src/lib/sna-run.ts",
      "types": "./dist/lib/sna-run.d.ts",
      "default": "./dist/lib/sna-run.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "predev": "lsof -ti:3099 | xargs kill -9 2>/dev/null; true",
    "dev": "tsx --watch src/server/standalone.ts",
    "test": "node --import tsx --test test/**/*.test.ts",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "claude-code",
    "sna",
    "skills-native",
    "skills-native-app",
    "hono"
  ],
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.0.0",
    "hono": "^4.12.7",
    "js-yaml": "^4.1.0",
    "marked": "^17.0.5"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "zustand": ">=4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "concurrently": "^9.2.1",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
